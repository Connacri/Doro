From adda75bb25f0c32f1737d1e0bba44550f537c4b0 Mon Sep 17 00:00:00 2001
From: Doro Dev <dev@doro.local>
Date: Fri, 3 Jul 2026 11:54:10 +0000
Subject: [PATCH] =?UTF-8?q?fix(p2p):=20sync=5Frequest=20sur=20le=20mauvais?=
 =?UTF-8?q?=20canal=20+=20wallet=20jamais=20cr=C3=A9dit=C3=A9=20apr=C3=A8s?=
 =?UTF-8?q?=20sync?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Bug 1 : _sendSyncRequest() envoyait le message via le WebSocket de
signaling (_signaling.send), qui ne relaie que offer/answer/ice/peer_list.
_handleSignal() n'a aucun case "sync_request" -> le message était
absorbé silencieusement côté pair receveur, sans log ni erreur.
Correctif : envoi via p2p.sendToPeer() sur le data channel WebRTC déjà
ouvert (cohérent avec _handleSyncRequest, qui répond par le même canal).

Bug 2 : _handleSyncResponse() appelait dag.restoreFinalized(tx) pour
chaque tx reçue, mais restoreFinalized() appelle finality.markFinalized()
directement SANS déclencher onFinalized -> _creditIfFinalizedHere()
n'était jamais appelé pour les tx rattrapées. Un appareil resynchronisé
retrouvait un DAG complet mais un solde de wallet resté à zéro.
Correctif : crédit explicite quand restoreFinalized() retourne accepted.

Ajout : chaque tx de sync repasse désormais par TxValidator + vérification
de signature Ed25519, comme une tx reçue en direct -- ne jamais faire
confiance aveuglément à la liste "finalisée" annoncée par un seul pair.
---
 lib/core/p2p/p2p_node.dart | 45 ++++++++++++++++++++++++++++++++++----
 1 file changed, 41 insertions(+), 4 deletions(-)

diff --git a/lib/core/p2p/p2p_node.dart b/lib/core/p2p/p2p_node.dart
index 3da7266..d44846d 100644
--- a/lib/core/p2p/p2p_node.dart
+++ b/lib/core/p2p/p2p_node.dart
@@ -115,10 +115,13 @@ class P2PNode {
     };
   }
 
+  /// Envoyé sur le DATA CHANNEL P2P (pas le WebSocket de signaling : ce
+  /// dernier ne relaie que offer/answer/ice/peer_list, et n'a aucun `case`
+  /// pour "sync_request" — l'envoyer par ce canal le fait disparaître
+  /// silencieusement côté pair receveur, sans erreur ni log).
   void _sendSyncRequest(String peerId) {
-    _signaling?.send({
+    p2p.sendToPeer(peerId, {
       "type": "sync_request",
-      "to": peerId,
       "from": nodeId,
     });
   }
@@ -245,12 +248,46 @@ class P2PNode {
     });
   }
 
+  /// Rattrapage reçu d'UN pair : chaque tx repasse par les mêmes contrôles
+  /// qu'une tx reçue en direct (structure + signature Ed25519) — le fait
+  /// qu'un pair l'annonce comme "finale" ne dispense jamais de vérifier
+  /// l'authenticité, sinon un seul pair malveillant pourrait injecter un
+  /// faux historique dans un nouvel appareil qui n'a encore aucune
+  /// référence locale pour le contredire.
+  ///
+  /// `restoreFinalized()` appelle `finality.markFinalized()` directement
+  /// SANS déclencher `onFinalized` (qui ne sert qu'au chemin de
+  /// confirmation "live"). Sans le crédit explicite ci-dessous, un
+  /// appareil qui rattrape son historique via sync verrait son DAG
+  /// complet mais son solde de wallet resterait à zéro pour tout ce
+  /// qu'il a "reçu" avant sa reconnexion.
   Future<void> _handleSyncResponse(Map<String, dynamic> data) async {
     final txs = data["txs"] as List?;
     if (txs == null) return;
+
     for (final item in txs) {
-      final tx = Transaction.fromJson(Map<String, dynamic>.from(item));
-      dag.restoreFinalized(tx);
+      late final Transaction tx;
+      try {
+        tx = Transaction.fromJson(Map<String, dynamic>.from(item));
+      } catch (e) {
+        Logger.warn("Tx de sync malformée ignorée : $e");
+        continue;
+      }
+
+      if (!_txValidator.validate(tx)) {
+        Logger.warn("Tx de sync ${tx.id} rejetée : validation structurelle échouée");
+        continue;
+      }
+
+      if (!await _verifySignature(tx)) {
+        Logger.warn("Tx de sync ${tx.id} rejetée : signature invalide");
+        continue;
+      }
+
+      final result = dag.restoreFinalized(tx);
+      if (result == DagAcceptResult.accepted) {
+        _creditIfFinalizedHere(tx);
+      }
     }
   }
 
