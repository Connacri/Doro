+import '../../dag/transaction_model.dart';
 
+/// Persiste les transactions FINALISÉES du DAG local (confirmées par au
+/// moins `requiredConfirmations` pairs distincts de l'émetteur), pour
+/// qu'elles survivent au redémarrage de l'app — ce que `DagEngine.ledger`
+/// (une simple Map en mémoire) ne fait pas seul.
+///
+/// Volontairement : seules les tx finales sont écrites ici. Une tx
+/// committée mais pas encore finale pourrait encore ne jamais être
+/// confirmée ; on ne veut acter dans le stockage que ce qui l'est déjà
+/// réellement, jamais un état provisoire.
+///
+/// Même pattern que `WalletRepository` (cache en mémoire + JSON dans
+/// shared_preferences) : pas de dépendance ObjectBox, qui n'est pas
+/// présente dans pubspec.yaml pour l'instant.
 class TxRepository {
-  final List<TxEntity> _cache = [];
+  final List<Transaction> _cache = [];
+  static const String _key = 'doro_finalized_txs';
 
-  void save(TxEntity tx) {
+  /// Ordre = ordre d'insertion = ordre de finalisation d'origine.
+  /// Important pour `DagEngine.restoreFinalized`, qui a besoin que les
+  /// parents d'une tx soient restaurés avant elle.
+  List<Transaction> all() => List.unmodifiable(_cache);
+
+  Future<void> saveFinalized(Transaction tx) async {
+    if (_cache.any((t) => t.id == tx.id)) return;
     _cache.add(tx);
+    await _persist();
+  }
+
+  Future<void> load() async {
+    final prefs = await SharedPreferences.getInstance();
+    final data = prefs.getStringList(_key);
+    if (data == null) return;
+
+    _cache.clear();
+    for (final item in data) {
+      _cache.add(Transaction.fromJson(jsonDecode(item) as Map<String, dynamic>));
+    }
   }
 
-  List<TxEntity> getAll() {
-    return List.unmodifiable(_cache);
+  Future<void> _persist() async {
+    final prefs = await SharedPreferences.getInstance();
+    final data = _cache.map((tx) => jsonEncode(tx.toJson())).toList();
+    await prefs.setStringList(_key, data);
   }
 }
